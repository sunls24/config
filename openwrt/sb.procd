#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=01

WORKDIR=/root/sb
PROG="$WORKDIR/sing-box"
CONFIG="$WORKDIR/config.json"

start_service() {
	[ -x "$PROG" ] || return 1
	[ -f "$CONFIG" ] || return 1

	procd_open_instance
	procd_set_param command "$PROG" -D "$WORKDIR" -c "$CONFIG" run
	procd_set_param file "$CONFIG"
	procd_set_param respawn
	procd_set_param stderr 1
	procd_set_param stdout 1
	procd_close_instance
}
